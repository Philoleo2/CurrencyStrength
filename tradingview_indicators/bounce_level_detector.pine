//@version=5
// ══════════════════════════════════════════════════════════════════════════════
//  BOUNCE LEVEL DETECTOR v3.1
//  Individua i livelli di prezzo (supporti/resistenze) basati sulle CHIUSURE,
//  assistiti da Pivot High/Low per identificare chiusure strutturalmente
//  rilevanti. Conta i rimbalzi (wick) nelle candele successive.
//
//  v3.1 — Correzioni:
//    • Il livello è SEMPRE il prezzo di chiusura (anche quando assistito da pivot)
//    • Le linee terminano alla fine della finestra di analisi, non al prezzo corrente
//    • Pivot usati come filtro per identificare chiusure near-swing
//  v3.0 — Pivot, clustering, tolleranza asimmetrica, fusione livelli
//  v2.1 — xloc.bar_time per evitare limiti di distanza bar_index
//  v2.0 — Tolleranza adattiva ATR per tutti i timeframe
//
//  USO:
//  1. Clicca sul grafico per selezionare la candela di partenza
//  2. L'indicatore registra la CHIUSURA di ogni candela come livello candidato
//  3. Opzionalmente, i Pivot High/Low filtrano le chiusure più significative
//  4. Per ogni livello, conta i rimbalzi nelle N candele successive
//  5. Mostra solo i livelli più "sentiti" dal prezzo
// ══════════════════════════════════════════════════════════════════════════════
indicator("Bounce Level Detector v3.1", "BounceLD v3.1", overlay=true, max_lines_count=500, max_labels_count=500)

// ─────────────────────────────────────────────────────────────────────────────
//  INPUTS
// ─────────────────────────────────────────────────────────────────────────────
var GRP1 = "⚙️ Parametri Principali"

i_startTime = input.time(timestamp("2025-01-01 00:00"), "📌 Candela di partenza (clicca sul grafico)",
     confirm=true, group=GRP1,
     tooltip="Clicca sulla candela da cui vuoi far partire l'analisi")

i_lookfwd = input.int(50, "🔭 Candele successive da analizzare",
     minval=3, maxval=500, group=GRP1,
     tooltip="Per ogni livello, quante candele successive controllare per i rimbalzi.\n50 consigliato.")

i_tolMode = input.string("Auto (ATR)", "📏 Modalità Tolleranza",
     options=["Auto (ATR)", "Manuale (ticks)"], group=GRP1,
     tooltip="Auto: tolleranza adattiva basata su ATR (consigliato per tutti i TF)\nManuale: tolleranza fissa in ticks")

i_tolTicks = input.int(5, "🎯 Tolleranza manuale (ticks)",
     minval=1, maxval=200, group=GRP1,
     tooltip="Usato solo in modalità Manuale.\n1 tick = minimo incremento di prezzo.")

i_atrLen = input.int(14, "📐 Periodo ATR (per Auto)",
     minval=5, maxval=200, group=GRP1)

i_atrMult = input.float(0.15, "📐 Moltiplicatore ATR",
     minval=0.01, maxval=1.0, step=0.01, group=GRP1,
     tooltip="tolleranza = ATR × questo valore.\n0.10 = stretto\n0.15 = medio (default)\n0.25 = largo")

i_minBounces = input.int(2, "⚡ Rimbalzi minimi per mostrare il livello",
     minval=1, maxval=50, group=GRP1)

i_maxLevels = input.int(15, "📊 Numero massimo di livelli da mostrare",
     minval=1, maxval=50, group=GRP1)

i_clusterMult = input.float(1.5, "🔗 Moltiplicatore cluster",
     minval=0.5, maxval=5.0, step=0.1, group=GRP1,
     tooltip="Livelli entro (tolleranza × questo valore) vengono fusi.\nEvita livelli duplicati troppo vicini.\n1.0 = stretto, 1.5 = medio, 2.5 = largo.")

var GRP15 = "🔬 Sorgenti Livello"

i_useAllCloses = input.bool(true, "📊 Registra TUTTE le chiusure come livelli", group=GRP15,
     tooltip="Registra la chiusura di ogni candela come livello candidato.\nAttivare per non perdere nessun livello potenziale.\nDisattivare per usare solo le chiusure vicine ai Pivot.")

i_usePivotClose = input.bool(true, "🔍 Registra chiusure vicino a Pivot High/Low", group=GRP15,
     tooltip="Quando un Pivot viene confermato, registra la chiusura della candela\npivot come livello. Cattura massimi/minimi strutturali usando il close.\nFunziona anche con 'Tutte le chiusure' attivo (evita duplicati).")

i_pivotLeft = input.int(5, "🔍 Barre sinistra per Pivot",
     minval=1, maxval=50, group=GRP15,
     tooltip="Barre a sinistra per confermare uno swing high/low.\n3-5 per TF bassi, 5-10 per TF alti.")

i_pivotRight = input.int(5, "🔍 Barre destra per Pivot",
     minval=1, maxval=50, group=GRP15,
     tooltip="Barre a destra per confermare uno swing high/low.\n3-5 per TF bassi, 5-10 per TF alti.")

var GRP2 = "🎨 Aspetto"

i_colSupp    = input.color(#00E676, "Colore Supporto ↑", group=GRP2)
i_colRes     = input.color(#FF5252, "Colore Resistenza ↓", group=GRP2)
i_colMix     = input.color(#FFD600, "Colore Misto ↕", group=GRP2)
i_lineW      = input.int(2, "Spessore linea", minval=1, maxval=5, group=GRP2)
i_showLbl    = input.bool(true, "Mostra etichette con conteggio rimbalzi", group=GRP2)
i_showPivots = input.bool(true, "🔹 Mostra marker sui pivot", group=GRP2,
     tooltip="Mostra piccoli triangoli dove vengono rilevati i pivot high/low")
i_showInfo   = input.bool(true, "Mostra pannello info", group=GRP2)

// ─────────────────────────────────────────────────────────────────────────────
//  TOLLERANZA (adattiva con ATR o fissa in ticks)
// ─────────────────────────────────────────────────────────────────────────────
atrVal = ta.atr(i_atrLen)
tol = i_tolMode == "Auto (ATR)" ? nz(atrVal, syminfo.mintick * 100) * i_atrMult : i_tolTicks * syminfo.mintick
clusterDist = tol * i_clusterMult

// ─────────────────────────────────────────────────────────────────────────────
//  PIVOT DETECTION (usati come filtro, il livello sarà sempre il close)
// ─────────────────────────────────────────────────────────────────────────────
ph = ta.pivothigh(high, i_pivotLeft, i_pivotRight)
pl = ta.pivotlow(low, i_pivotLeft, i_pivotRight)

// ─────────────────────────────────────────────────────────────────────────────
//  VARIABILI DI STATO
// ─────────────────────────────────────────────────────────────────────────────

// Livelli attivi (in fase di valutazione)
var float[] aLvl = array.new_float()   // prezzo di chiusura del livello
var int[]   aBar = array.new_int()     // bar_index della chiusura
var int[]   aTm  = array.new_int()     // timestamp della chiusura
var int[]   aTot = array.new_int()     // rimbalzi totali
var int[]   aBul = array.new_int()     // rimbalzi supporto (verso l'alto)
var int[]   aBer = array.new_int()     // rimbalzi resistenza (verso il basso)

// Livelli completati (finestra terminata, qualificati)
var float[] cLvl   = array.new_float()
var int[]   cBar   = array.new_int()
var int[]   cTm    = array.new_int()
var int[]   cTmEnd = array.new_int()
var int[]   cTot   = array.new_int()
var int[]   cBul   = array.new_int()
var int[]   cBer   = array.new_int()

// Handle per i disegni
var line[]  gLines  = array.new_line()
var label[] gLabels = array.new_label()

// Rilevamento candela di partenza
var int   startBI = na
var int   startTm = na
var float startHi = na
var float startLo = na
var bool  started = false

if not started and time >= i_startTime
    startBI := bar_index
    startTm := time
    startHi := high
    startLo := low
    started := true

go = started and bar_index >= startBI

// Durata di una barra in millisecondi (per offset label)
barDur = time - time[1]

// ─────────────────────────────────────────────────────────────────────────────
//  MARKER PIVOT (plotshape — deve essere al top-level)
// ─────────────────────────────────────────────────────────────────────────────
plotshape(i_showPivots and i_usePivotClose and go and not na(ph) ? ph : na,
     "Pivot High", shape.triangledown, location.absolute,
     color.new(i_colRes, 40), offset=-i_pivotRight, size=size.tiny)
plotshape(i_showPivots and i_usePivotClose and go and not na(pl) ? pl : na,
     "Pivot Low", shape.triangleup, location.absolute,
     color.new(i_colSupp, 40), offset=-i_pivotRight, size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
//  FUNZIONE HELPER: controlla se un livello è troppo vicino a quelli esistenti
// ─────────────────────────────────────────────────────────────────────────────
canAddLevel(float price) =>
    result = true
    nAct = array.size(aLvl)
    if nAct > 0
        for ci = 0 to nAct - 1
            if math.abs(array.get(aLvl, ci) - price) <= clusterDist
                result := false
                break
    if result
        nCmp = array.size(cLvl)
        if nCmp > 0
            for ci = 0 to nCmp - 1
                if math.abs(array.get(cLvl, ci) - price) <= clusterDist
                    result := false
                    break
    result

// ─────────────────────────────────────────────────────────────────────────────
//  LOGICA PRINCIPALE — eseguita una volta per candela confermata
// ─────────────────────────────────────────────────────────────────────────────

if go and barstate.isconfirmed

    // ╔═══════════════════════════════════════════════════════════════════════╗
    // ║  STEP 1: Controlla candela corrente contro tutti i livelli attivi    ║
    // ╚═══════════════════════════════════════════════════════════════════════╝
    nA = array.size(aLvl)
    if nA > 0
        for i = 0 to nA - 1
            lev = array.get(aLvl, i)
            bi  = array.get(aBar, i)

            if bar_index > bi and bar_index <= bi + i_lookfwd

                // ── Rimbalzo SUPPORTO ──
                // Low tocca o oltrepassa leggermente il livello (tolleranza asimmetrica)
                // Permette al wick di andare fino a 2×tol sotto (rejection candle)
                supportBounce = low >= lev - tol * 2 and low <= lev + tol and close > lev

                // ── Rimbalzo RESISTENZA ──
                // High tocca o oltrepassa leggermente il livello
                // Permette al wick di andare fino a 2×tol sopra
                resistBounce = high >= lev - tol and high <= lev + tol * 2 and close < lev

                if supportBounce
                    array.set(aTot, i, array.get(aTot, i) + 1)
                    array.set(aBul, i, array.get(aBul, i) + 1)
                else if resistBounce
                    array.set(aTot, i, array.get(aTot, i) + 1)
                    array.set(aBer, i, array.get(aBer, i) + 1)

    // ╔═══════════════════════════════════════════════════════════════════════╗
    // ║  STEP 2: Finalizza livelli con finestra completata                   ║
    // ╚═══════════════════════════════════════════════════════════════════════╝
    j = array.size(aLvl) - 1
    while j >= 0
        if bar_index >= array.get(aBar, j) + i_lookfwd
            tot = array.get(aTot, j)
            if tot >= i_minBounces
                lvlPrice = array.get(aLvl, j)
                // Cerca cluster con livelli completati esistenti
                merged = false
                cSzJ = array.size(cLvl)
                if cSzJ > 0
                    for ci = 0 to cSzJ - 1
                        if math.abs(array.get(cLvl, ci) - lvlPrice) <= clusterDist
                            existTot = array.get(cTot, ci)
                            newTot   = existTot + tot
                            newPrice = (array.get(cLvl, ci) * existTot + lvlPrice * tot) / newTot
                            array.set(cLvl, ci, newPrice)
                            array.set(cTot, ci, newTot)
                            array.set(cBul, ci, array.get(cBul, ci) + array.get(aBul, j))
                            array.set(cBer, ci, array.get(cBer, ci) + array.get(aBer, j))
                            if array.get(aTm, j) < array.get(cTm, ci)
                                array.set(cTm, ci, array.get(aTm, j))
                                array.set(cBar, ci, array.get(aBar, j))
                            array.set(cTmEnd, ci, time)
                            merged := true
                            break

                if not merged
                    array.push(cLvl,   lvlPrice)
                    array.push(cBar,   array.get(aBar, j))
                    array.push(cTm,    array.get(aTm, j))
                    array.push(cTmEnd, time)
                    array.push(cTot,   tot)
                    array.push(cBul,   array.get(aBul, j))
                    array.push(cBer,   array.get(aBer, j))

            array.remove(aLvl, j)
            array.remove(aBar, j)
            array.remove(aTm,  j)
            array.remove(aTot, j)
            array.remove(aBul, j)
            array.remove(aBer, j)
        j -= 1

    // ╔═══════════════════════════════════════════════════════════════════════╗
    // ║  STEP 3: Registra nuovi livelli (SEMPRE basati su chiusura)          ║
    // ╚═══════════════════════════════════════════════════════════════════════╝

    // ── Chiusure vicino a Pivot High/Low confermati ──
    // Il pivot identifica la struttura, ma il livello è il CLOSE della candela pivot
    if i_usePivotClose
        if not na(ph)
            pivotCloseH = close[i_pivotRight]
            pivotBarH   = bar_index - i_pivotRight
            pivotTmH    = time[i_pivotRight]
            if canAddLevel(pivotCloseH)
                array.push(aLvl, pivotCloseH)
                array.push(aBar, pivotBarH)
                array.push(aTm,  pivotTmH)
                array.push(aTot, 0)
                array.push(aBul, 0)
                array.push(aBer, 0)

        if not na(pl)
            pivotCloseL = close[i_pivotRight]
            pivotBarL   = bar_index - i_pivotRight
            pivotTmL    = time[i_pivotRight]
            if canAddLevel(pivotCloseL)
                array.push(aLvl, pivotCloseL)
                array.push(aBar, pivotBarL)
                array.push(aTm,  pivotTmL)
                array.push(aTot, 0)
                array.push(aBul, 0)
                array.push(aBer, 0)

    // ── Tutte le chiusure ──
    if i_useAllCloses
        if canAddLevel(close)
            array.push(aLvl, close)
            array.push(aBar, bar_index)
            array.push(aTm,  time)
            array.push(aTot, 0)
            array.push(aBul, 0)
            array.push(aBer, 0)

// ─────────────────────────────────────────────────────────────────────────────
//  RENDERING — solo sull'ultima barra per efficienza
//  Usa xloc.bar_time per evitare il limite di distanza bar_index
// ─────────────────────────────────────────────────────────────────────────────
if barstate.islast

    // Pulisci tutti i disegni precedenti
    while array.size(gLines) > 0
        line.delete(array.pop(gLines))
    while array.size(gLabels) > 0
        label.delete(array.pop(gLabels))

    // ── Marcatore candela di partenza ──
    if not na(startTm)
        startLn = line.new(startTm, startLo * 0.9999, startTm, startHi * 1.0001,
             xloc=xloc.bar_time,
             color=color.new(color.gray, 30), width=1, style=line.style_dashed)
        array.push(gLines, startLn)

        startLb = label.new(startTm, startHi, "▶ START",
             xloc=xloc.bar_time,
             color=color.new(color.gray, 20), textcolor=color.white,
             style=label.style_label_down, size=size.small)
        array.push(gLabels, startLb)

    // ── Unifica livelli completati + attivi qualificati ──
    float[] mP    = array.new_float()    // prezzo
    int[]   mTm   = array.new_int()      // timestamp inizio
    int[]   mTmE  = array.new_int()      // timestamp fine
    int[]   mT    = array.new_int()      // totale rimbalzi
    int[]   mU    = array.new_int()      // rimbalzi supporto
    int[]   mD    = array.new_int()      // rimbalzi resistenza
    bool[]  mAc   = array.new_bool()     // true = ancora in valutazione

    // Aggiungi livelli completati — linea termina alla fine della finestra
    cSz = array.size(cLvl)
    if cSz > 0
        for i = 0 to cSz - 1
            array.push(mP,   array.get(cLvl, i))
            array.push(mTm,  array.get(cTm, i))
            array.push(mTmE, array.get(cTmEnd, i))
            array.push(mT,   array.get(cTot, i))
            array.push(mU,   array.get(cBul, i))
            array.push(mD,   array.get(cBer, i))
            array.push(mAc,  false)

    // Aggiungi livelli attivi che già qualificano
    aSz = array.size(aLvl)
    if aSz > 0
        for i = 0 to aSz - 1
            if array.get(aTot, i) >= i_minBounces
                array.push(mP,   array.get(aLvl, i))
                array.push(mTm,  array.get(aTm, i))
                array.push(mTmE, time)
                array.push(mT,   array.get(aTot, i))
                array.push(mU,   array.get(aBul, i))
                array.push(mD,   array.get(aBer, i))
                array.push(mAc,  true)

    // ── Ordinamento parziale per rimbalzi (decrescente) ──
    sz = array.size(mP)
    drawN = 0

    if sz > 0
        int[] si = array.new_int(sz)
        for i = 0 to sz - 1
            array.set(si, i, i)

        lim = math.min(sz - 1, i_maxLevels - 1)
        if sz > 1
            for i = 0 to lim
                mx = i
                mv = array.get(mT, array.get(si, i))
                if i + 1 <= sz - 1
                    for k = i + 1 to sz - 1
                        v = array.get(mT, array.get(si, k))
                        if v > mv
                            mx := k
                            mv := v
                if mx != i
                    tmp = array.get(si, i)
                    array.set(si, i, array.get(si, mx))
                    array.set(si, mx, tmp)

        // ── Disegna i migliori livelli ──
        drawN := math.min(sz, i_maxLevels)
        for i = 0 to drawN - 1
            ii   = array.get(si, i)
            p    = array.get(mP, ii)
            tm1  = array.get(mTm, ii)
            tm2  = array.get(mTmE, ii)
            t    = array.get(mT, ii)
            bu   = array.get(mU, ii)
            be   = array.get(mD, ii)
            act  = array.get(mAc, ii)

            col = bu > be ? i_colSupp : be > bu ? i_colRes : i_colMix
            alpha = math.max(0, 70 - t * 8)
            sty = act ? line.style_dashed : line.style_solid

            ln = line.new(tm1, p, tm2, p,
                 xloc=xloc.bar_time,
                 color=color.new(col, alpha), width=i_lineW, style=sty)
            array.push(gLines, ln)

            if i_showLbl
                sfx = act ? " ⏳" : ""
                txt = str.tostring(t) + "×" + sfx
                tip = "📍 Prezzo: " + str.tostring(p, format.mintick) +
                     "\n📊 Rimbalzi totali: " + str.tostring(t) +
                     "\n↑ Supporto: " + str.tostring(bu) +
                     "\n↓ Resistenza: " + str.tostring(be) +
                     (act ? "\n⏳ Ancora in valutazione" : "\n✅ Analisi completata")
                lb = label.new(tm2 + nz(barDur, 60000), p, txt,
                     xloc=xloc.bar_time,
                     color=color.new(col, math.max(0, alpha - 10)),
                     textcolor=color.white,
                     style=label.style_label_left,
                     size=size.small,
                     tooltip=tip)
                array.push(gLabels, lb)

    // ── Pannello informativo ──
    if i_showInfo
        var table infoTbl = table.new(position.top_right, 2, 7,
             bgcolor=color.new(#1a1a2e, 10), border_width=1, border_color=color.new(color.gray, 60))

        table.cell(infoTbl, 0, 0, "BounceLD v3.1", text_color=color.white, text_size=size.small, text_halign=text.align_left)
        table.cell(infoTbl, 1, 0, "", text_size=size.small)

        table.cell(infoTbl, 0, 1, "Livelli mostrati", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
        table.cell(infoTbl, 1, 1, str.tostring(drawN) + " / " + str.tostring(sz), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)

        srcTxt = (i_useAllCloses ? "Close" : "") + (i_useAllCloses and i_usePivotClose ? " + " : "") + (i_usePivotClose ? "PivotClose" : "")
        table.cell(infoTbl, 0, 2, "Sorgenti", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
        table.cell(infoTbl, 1, 2, srcTxt, text_color=color.white, text_size=size.tiny, text_halign=text.align_right)

        table.cell(infoTbl, 0, 3, "Finestra", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
        table.cell(infoTbl, 1, 3, str.tostring(i_lookfwd) + " candele", text_color=color.white, text_size=size.tiny, text_halign=text.align_right)

        table.cell(infoTbl, 0, 4, "Modalità tol.", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
        table.cell(infoTbl, 1, 4, i_tolMode, text_color=color.white, text_size=size.tiny, text_halign=text.align_right)

        tolTxt = i_tolMode == "Auto (ATR)" ? str.tostring(tol, format.mintick) + " (ATR×" + str.tostring(i_atrMult) + ")" : str.tostring(i_tolTicks) + " ticks"
        table.cell(infoTbl, 0, 5, "Tolleranza", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
        table.cell(infoTbl, 1, 5, tolTxt, text_color=color.white, text_size=size.tiny, text_halign=text.align_right)

        table.cell(infoTbl, 0, 6, "Min rimbalzi", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
        table.cell(infoTbl, 1, 6, str.tostring(i_minBounces), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
// ══════════════════════════════════════════════════════════════════════════════
